# LLM Configuration (Groq is used for summarization)
GROQ_API_KEY="your_groq_api_key_here"

# Embedding Model Configuration (using BGE small model for local embeddings)
# We will use sentence-transformers with the BAAI/bge-small-en-v1.5 model.
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"

# Google Docs & Gmail Delivery (Phase 4)
# No local Google OAuth credentials are required. The CLI communicates 
# directly with the remote Railway delivery API.
